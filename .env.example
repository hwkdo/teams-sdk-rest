# Bot authentication (Teams SDK)
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=

# Optional: Public | USGov | USGovDoD | China
# CLOUD=Public

PORT=3978

# REST API protection (Laravel -> container)
API_KEY=change-me-to-a-secure-random-string

# Event forwarding (container -> Laravel)
LARAVEL_WEBHOOK_URL=https://your-laravel-app.example/api/kunden/ms-graph-laravel/teams-webhook
LARAVEL_WEBHOOK_SECRET=

# Welcome message after bot installation (empty = disabled)
WELCOME_MESSAGE=Bot installiert — bereit für Benachrichtigungen.

# SQLite persistence
DATA_DIR=/data
